{
  "$schema": "../schema.json",
  "id": "google-cloud-storage",
  "name": "Google Cloud Storage",
  "type": "hyperscaler",
  "url": "https://cloud.google.com/storage",
  "verified": "Apr 2026",
  "bestFor": ["datalake", "aiml"],
  "migrationEase": "High (S3 interop API)",
  "gotchas": "Highest egress ($0.12/GB). S3 compat is interop layer, not native. 365-day Archive min retention.",
  "pricing": {
    "storageStd": 0.020,
    "storageIA": 0.010,
    "storageArchive": 0.0012,
    "storageDeep": null,
    "egressPerGB": 0.12,
