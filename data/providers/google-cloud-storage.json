    "reqLimitPUT": "1,000/s per bucket",
    "throttle": "429 backoff"
  },
  "limits": {
    "maxBuckets": "No hard limit",
    "maxObjSize": "5 TB",
    "maxMetaKB": "8 KB"
  },
  "dataProtection": {
    "replication": true,
    "replRPO": "~15 min (Turbo: 0 RPO)",
    "softDelete": true,
    "legalHold": true,
    "mfaDelete": false,
    "pitRestore": false
  },
  "advancedS3": {
    "selectQuery": false,
    "batchOps": true,
    "inventory": true,
    "accessLog": true,
